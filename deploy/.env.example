# Copy to /opt/arb/.env on the server, fill in, chmod 600. Never commit the
# filled-in version.

# Public hostname Caddy requests the certificate for.
DOMAIN=arb-screener.duckdns.org

# Shared bearer token required from every WS/REST client.
# Generate with:  openssl rand -hex 32
ARB_AUTH_TOKEN=

# Image to run. Override to pin a specific commit instead of :latest.
ARB_IMAGE=ghcr.io/martynov-lab/crypto_server:latest

RUST_LOG=info

# --- Optional config overrides (ARB__ prefix, __ = nesting) ---
# The VM has 1 GB RAM; lower this if the container starts hitting mem_limit.
# ARB__INGEST__MAX_SYMBOLS=100
